[Unit]
Description=smock (well app)
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/smock
ExecStart=/opt/smock/bin/smock
Restart=on-failure
RestartSec=3

EnvironmentFile=/opt/smock/.env

# Hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/opt/smock
PrivateTmp=yes

# Allow binding to privileged ports (443, 80)
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
